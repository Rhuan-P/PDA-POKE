{
  "name": "pda-poke",
  "version": 2,
  "builds": [
    {
      "src": "api/pokemon.js",
      "use": "@vercel/node"
    },
    {
      "src": "api/battle.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/pokemon/(.*)",
      "dest": "/api/pokemon.js"
    },
    {
      "src": "/api/battle/(.*)",
      "dest": "/api/battle.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}