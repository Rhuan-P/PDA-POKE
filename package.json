{
  "name": "pokemon-battle-simulator",
  "version": "0.1.0",
  "description": "Simulador de batalhas Pokémon com arquitetura limpa",
  "main": "src/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "nodemon src/server.js",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "build:server": "tsc",
    "preview": "vite preview",
    "start": "node dist/server.js",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:unit": "jest --config jest.config.cjs --testPathPattern=tests/unit",
    "test:integration": "jest --config jest.config.cjs --testPathPattern=tests/integration",
    "test:e2e": "jest --config jest.config.cjs --testPathPattern=tests/e2e",
    "check:docs": "node scripts/validate-doc-paths.cjs",
    "lint": "eslint src/**/*.{js,vue,ts}",
    "lint:fix": "eslint src/**/*.{js,vue,ts} --fix"
  },
  "keywords": [
    "pokemon",
    "battle",
    "simulator",
    "vue",
    "typescript",
    "clean-architecture"
  ],
  "author": "Líder do Projeto",
  "license": "MIT",
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^29.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "eslint": "^8.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vite": "^4.0.0"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "express": "^4.22.1",
    "helmet": "^7.2.0",
    "morgan": "^1.10.1",
    "nodemon": "^3.1.14",
    "pinia": "^2.1.0",
    "vue": "^3.3.0",
    "vue-router": "^4.6.4"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
