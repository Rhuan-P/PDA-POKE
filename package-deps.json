{
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/jest": "^29.0.0",
    "@vitejs/plugin-vue": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^4.0.0",
    "jest": "^29.0.0",
    "eslint": "^8.0.0",
    "ts-jest": "^29.1.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vue/eslint-config-typescript": "^12.0.0",
    "eslint-plugin-vue": "^9.0.0",
    "nodemon": "^3.0.1",
    "concurrently": "^8.2.0"
  },
  "scripts": {
    "dev": "vite",
    "dev:server": "nodemon src/server.js",
    "dev:full": "concurrently \"npm run dev:server\" \"npm run dev\"",
    "build": "vite build",
    "preview": "vite preview",
    "start": "node src/server.js",
    "test": "jest --config jest.config.cjs",
    "test:watch": "jest --config jest.config.cjs --watch",
    "test:unit": "jest --config jest.config.cjs --testPathPattern=tests/unit",
    "test:integration": "jest --config jest.config.cjs --testPathPattern=tests/integration",
    "test:e2e": "jest --config jest.config.cjs --testPathPattern=tests/e2e",
    "check:docs": "node scripts/validate-doc-paths.cjs",
    "lint": "eslint src/**/*.{js,vue,ts}",
    "lint:fix": "eslint src/**/*.{js,vue,ts} --fix"
  }
}
